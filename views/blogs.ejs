<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blogs | QuickTow</title>
    <link rel="stylesheet" href="/css/styles.css">
    <% if (lang === 'ur') { %>
    <style>body { direction: rtl; text-align: right; } .navbar-brand { flex-direction: row-reverse; } .navbar-links { flex-direction: row-reverse; } .tracking-search { flex-direction: row-reverse; }</style>
    <% } %>
</head>
<body>
<a href="?lang=<%= langSwitch %>" class="lang-btn" style="position:fixed;top:90px;right:25px;z-index:9999;background:linear-gradient(135deg,#f39c12,#e67e22);color:white;border:3px solid white;padding:12px 24px;border-radius:50px;font-weight:800;font-size:1.05rem;cursor:pointer;box-shadow:0 6px 25px rgba(0,0,0,0.3);transition:all 0.3s ease;text-decoration:none;display:flex;align-items:center;gap:8px;">🌐 <%= lang === 'en' ? 'اردو' : 'English' %></a>

    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/" class="navbar-brand">
                <span class="logo-icon">🚛</span>
                QuickTow
            </a>
            <div class="navbar-links">
                <a href="/booking"><%= t.nav.booking %></a>
                <a href="/track"><%= t.nav.track %></a>
                <a href="/blogs" class="active"><%= t.nav.blogs %></a>
                <a href="/about"><%= t.nav.about %></a>
                <a href="/booking" class="cta"><%= t.nav.emergency %></a>
            </div>
        </div>
    </nav>

    <div class="hero">
        <h1><%= t.blogs.title %></h1>
        <p><%= t.blogs.subtitle %></p>
    </div>

    <div class="container">
        <% if(blogs.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon">📝</div>
                <h3><%= t.blogs.no_articles %></h3>
                <p><%= t.blogs.no_articles_desc %></p>
            </div>
        <% } else { %>
            <div class="blog-grid">
                <% blogs.forEach(function(blog, index) { %>
                    <div class="blog-card" style="animation-delay: <%= index * 0.1 %>s;">
                        <h3><%= blog.title %></h3>
                        <p><%= blog.content %></p>
                        <small>📅 <%= t.blogs.published %> <%= new Date(blog.created_at).toLocaleDateString() %></small>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    <footer class="footer">
        <p>&copy; <%= t.footer.copyright %></p>
    </footer>

</body>
</html>
