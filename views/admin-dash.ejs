<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | QuickTow</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/<%= adminPath %>/dashboard" class="navbar-brand">
                <span class="logo-icon">🚛</span>
                QuickTow Admin
            </a>
            <div class="navbar-links">
                <a href="/" class="nav-admin">🏠 Home</a>
                <a href="/<%= adminPath %>/dashboard" class="active">Dashboard</a>
                <a href="/driver" class="cta" style="background: linear-gradient(135deg, var(--accent), var(--accent-dark));">👨‍✈️ Driver Login</a>
                <a href="/<%= adminPath %>/logout" class="cta" style="background: linear-gradient(135deg, var(--danger), #c0392b);">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="dash-header">
            <h1>📊 Control Panel Dashboard</h1>
        </div>

        <div class="stat-cards">
            <div class="stat-card">
                <div class="stat-icon orange">📋</div>
                <div class="stat-info">
                    <h4><%= stats.total %></h4>
                    <p>Total Bookings</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon yellow">⏳</div>
                <div class="stat-info">
                    <h4><%= stats.pending %></h4>
                    <p>Pending</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon blue">🚛</div>
                <div class="stat-info">
                    <h4><%= stats.active %></h4>
                    <p>Active</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green">✅</div>
                <div class="stat-info">
                    <h4><%= stats.completed %></h4>
                    <p>Completed</p>
                </div>
            </div>
        </div>

        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab(event, 'bookings')">📋 Bookings</button>
            <button class="tab-btn" onclick="switchTab(event, 'drivers')">👨‍✈️ Drivers</button>
            <button class="tab-btn" onclick="switchTab(event, 'add-driver')">➕ Add Driver</button>
            <button class="tab-btn" onclick="switchTab(event, 'add-blog')">✍️ Blog</button>
        </div>

        <!-- BOOKINGS TAB -->
        <div class="tab-content active" id="tab-bookings">
            <div class="dash-section">
                <h3>📋 All Bookings (<%= bookings.length %>)</h3>
                <% if(bookings.length === 0) { %>
                    <div class="empty-state">
                        <div class="empty-icon">📭</div>
                        <h3>No Bookings Yet</h3>
                        <p>When customers book a tow, it will appear here.</p>
                    </div>
                <% } else { %>
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Customer</th>
                                    <th>Phone</th>
                                    <th>Vehicle</th>
                                    <th>Pickup</th>
                                    <th>Dropoff</th>
                                    <th>Type</th>
                                    <th>Code</th>
                                    <th>Status</th>
                                    <th>Driver</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% bookings.forEach(function(b) { %>
                                    <tr id="row-<%= b.id %>">
                                        <td><strong style="color: var(--primary);">#<%= b.id %></strong></td>
                                        <td><strong><%= b.customer_name %></strong></td>
                                        <td><%= b.phone %></td>
                                        <td><%= b.car_model %></td>
                                        <td><%= b.pickup_location %></td>
                                        <td><%= b.dropoff_location %></td>
                                        <td><span class="badge badge-assigned"><%= b.service_type %></span></td>
                                        <td><strong style="color: var(--accent);"><%= b.tracking_code %></strong></td>
                                        <td><span class="badge badge-<%= b.status %>"><%= b.status.replaceAll('_', ' ') %></span></td>
                                        <td>
                                            <% if(b.driver_id) { %>
                                                <span style="color: var(--accent); font-weight: 600;">✓ Assigned</span>
                                            <% } else { %>
                                                <span style="color: var(--danger); font-weight: 600;">✗ None</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
                                                <% if(!b.driver_id && b.status === 'pending') { %>
                                                    <button class="btn btn-primary btn-sm" onclick="openAssignModal(<%= b.id %>)">👨‍✈️ Assign</button>
                                                <% } %>
                                                <select onchange="updateBookingStatus(<%= b.id %>, this.value)" style="padding: 8px 12px; border: 2px solid #e1e5e9; border-radius: 8px; font-size: 0.85rem; font-family: inherit; cursor: pointer; transition: all 0.3s ease;">
                                                    <option value="" disabled selected>Status</option>
                                                    <option value="pending">⏳ Pending</option>
                                                    <option value="assigned">👨‍✈️ Assigned</option>
                                                    <option value="dispatched">🚛 Dispatched</option>
                                                    <option value="on_the_way">🛣️ On The Way</option>
                                                    <option value="arrived">📍 Arrived</option>
                                                    <option value="completed">✅ Completed</option>
                                                    <option value="cancelled">❌ Cancelled</option>
                                                </select>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- DRIVERS TAB -->
        <div class="tab-content" id="tab-drivers">
            <div class="dash-section">
                <h3>👨‍✈️ All Drivers (<%= drivers.length %>)</h3>
                <% if(drivers.length === 0) { %>
                    <div class="empty-state">
                        <div class="empty-icon">👨‍✈️</div>
                        <h3>No Drivers Added Yet</h3>
                        <p>Add drivers from the "Add Driver" tab.</p>
                    </div>
                <% } else { %>
                    <div class="driver-grid">
                        <% drivers.forEach(function(d) { %>
                            <div class="driver-card">
                                <div class="driver-avatar">🚛</div>
                                <div class="driver-info">
                                    <h4><%= d.name %></h4>
                                    <p>📞 <%= d.phone %> | 🚗 <%= d.truck_number %></p>
                                    <div style="margin-top: 8px; display: flex; gap: 6px; flex-wrap: wrap;">
                                        <span class="badge badge-<%= d.status %>"><%= d.status.replaceAll('_', ' ') %></span>
                                        <span class="badge badge-assigned"><%= d.truck_type %></span>
                                    </div>
                                </div>
                                <button class="btn btn-danger btn-sm" onclick="deleteDriver(<%= d.id %>)" style="padding: 10px 14px; font-size: 1rem;">🗑️</button>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- ADD DRIVER TAB -->
        <div class="tab-content" id="tab-add-driver">
            <div class="dash-section" style="max-width: 550px;">
                <h3>➕ Add New Driver</h3>
                <form action="/<%= adminPath %>/add-driver" method="POST" id="addDriverForm">
                    <div class="form-group">
                        <label>Driver Name</label>
                        <input type="text" class="form-control" name="name" placeholder="e.g. Ahmed Khan" required>
                    </div>
                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="tel" class="form-control" name="phone" placeholder="e.g. 03001234567" required>
                    </div>
                    <div class="form-group">
                        <label>Truck Type</label>
                        <select class="form-control" name="truck_type" required>
                            <option value="standard">Standard Tow</option>
                            <option value="flatbed">Flatbed Carrier</option>
                            <option value="accident_recovery">Accident Recovery</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Truck Number</label>
                        <input type="text" class="form-control" name="truck_number" placeholder="e.g. TK-1234" required>
                    </div>
                    <button type="submit" class="btn btn-success btn-block btn-lg" id="addDriverBtn">➕ Add Driver</button>
                </form>
            </div>
        </div>

        <!-- ADD BLOG TAB -->
        <div class="tab-content" id="tab-add-blog">
            <div class="dash-section" style="max-width: 650px;">
                <h3>✍️ Publish Article</h3>
                <form action="/<%= adminPath %>/add-blog" method="POST" id="addBlogForm">
                    <div class="form-group">
                        <label>Title</label>
                        <input type="text" class="form-control" name="title" placeholder="Enter Heading" required>
                    </div>
                    <div class="form-group">
                        <label>Content</label>
                        <textarea class="form-control" name="content" placeholder="Type blog text here..." rows="8" required style="resize: vertical;"></textarea>
                    </div>
                    <button type="submit" class="btn btn-success btn-block btn-lg" id="publishBlogBtn">📤 Publish</button>
                </form>
            </div>
        </div>
    </div>

    <!-- ASSIGN DRIVER MODAL -->
    <div class="modal-overlay" id="assignModal">
        <div class="modal">
            <h3>👨‍✈️ Assign Driver to Booking #<span id="modalBookingId"></span></h3>
            <select id="driverSelect" class="form-control">
                <option value="">Select a driver...</option>
                <% drivers.filter(function(d) { return d.status === 'available'; }).forEach(function(d) { %>
                    <option value="<%= d.id %>"><%= d.name %> - <%= d.truck_number %> (<%= d.truck_type %>)</option>
                <% }) %>
            </select>
            <div style="display: flex; gap: 12px; margin-top: 1.5rem;">
                <button class="btn btn-primary" onclick="assignDriver()" id="assignBtn">✅ Assign</button>
                <button class="btn btn-secondary" onclick="closeAssignModal()">Cancel</button>
            </div>
        </div>
    </div>

    <footer class="footer">
        <p>&copy; 2026 QuickTow. All rights reserved.</p>
    </footer>

    <script>
        let currentBookingId = null;
        const adminPath = '<%= adminPath %>';

        function switchTab(e, tabName) {
            document.querySelectorAll('.tab-content').forEach(function(el) {
                el.classList.remove('active');
            });
            document.querySelectorAll('.tab-btn').forEach(function(el) {
                el.classList.remove('active');
            });
            document.getElementById('tab-' + tabName).classList.add('active');
            e.target.classList.add('active');
        }

        function openAssignModal(bookingId) {
            currentBookingId = bookingId;
            document.getElementById('modalBookingId').textContent = bookingId;
            document.getElementById('assignModal').classList.add('active');
        }

        function closeAssignModal() {
            document.getElementById('assignModal').classList.remove('active');
            currentBookingId = null;
            document.getElementById('driverSelect').value = '';
        }

        async function assignDriver() {
            const driverId = document.getElementById('driverSelect').value;
            if (!driverId) { 
                alert('Please select a driver'); 
                return; 
            }
            
            const btn = document.getElementById('assignBtn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '⏳ Assigning...';
            btn.disabled = true;
            
            try {
                const res = await fetch('/' + adminPath + '/assign-driver', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ booking_id: currentBookingId, driver_id: driverId })
                });
                const data = await res.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error assigning driver: ' + (data.error || 'Unknown error'));
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            } catch (err) {
                alert('Error assigning driver. Please try again.');
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }

        async function updateBookingStatus(bookingId, status) {
            try {
                const res = await fetch('/' + adminPath + '/update-booking-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ booking_id: bookingId, status: status })
                });
                const data = await res.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error updating status: ' + (data.error || 'Unknown error'));
                }
            } catch (err) {
                alert('Error updating status. Please try again.');
            }
        }

        async function deleteDriver(driverId) {
            if (!confirm('Are you sure you want to delete this driver? This action cannot be undone.')) return;
            
            try {
                const res = await fetch('/' + adminPath + '/delete-driver', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ driver_id: driverId })
                });
                const data = await res.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error deleting driver: ' + (data.error || 'Unknown error'));
                }
            } catch (err) {
                alert('Error deleting driver. Please try again.');
            }
        }

        // Form loading states
        document.getElementById('addDriverForm').addEventListener('submit', function() {
            const btn = document.getElementById('addDriverBtn');
            btn.innerHTML = '⏳ Adding...';
            btn.disabled = true;
        });

        document.getElementById('addBlogForm').addEventListener('submit', function() {
            const btn = document.getElementById('publishBlogBtn');
            btn.innerHTML = '⏳ Publishing...';
            btn.disabled = true;
        });

        // Close modal on outside click
        document.getElementById('assignModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeAssignModal();
            }
        });

        // Close modal on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeAssignModal();
            }
        });
    </script>

</body>
</html>
