<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us | QuickTow</title>
    <link rel="stylesheet" href="/css/styles.css">
    <% if (lang === 'ur') { %>
    <style>body { direction: rtl; text-align: right; } .navbar-brand { flex-direction: row-reverse; } .navbar-links { flex-direction: row-reverse; } .tracking-search { flex-direction: row-reverse; }</style>
    <% } %>
</head>
<body>
<a href="?lang=<%= langSwitch %>" class="lang-btn" style="position:fixed;top:90px;right:25px;z-index:9999;background:linear-gradient(135deg,#f39c12,#e67e22);color:white;border:3px solid white;padding:12px 24px;border-radius:50px;font-weight:800;font-size:1.05rem;cursor:pointer;box-shadow:0 6px 25px rgba(0,0,0,0.3);transition:all 0.3s ease;text-decoration:none;display:flex;align-items:center;gap:8px;">🌐 <%= lang === 'en' ? 'اردو' : 'English' %></a>

    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/" class="navbar-brand">
                <span class="logo-icon">🚛</span>
                QuickTow
            </a>
            <div class="navbar-links">
                <a href="/booking"><%= t.nav.booking %></a>
                <a href="/track"><%= t.nav.track %></a>
                <a href="/blogs"><%= t.nav.blogs %></a>
                <a href="/about" class="active"><%= t.nav.about %></a>
                <a href="/booking" class="cta"><%= t.nav.emergency %></a>
            </div>
        </div>
    </nav>

    <div class="about-hero">
        <h1><%= t.about.title %></h1>
        <p><%= t.about.subtitle %></p>
    </div>

    <div class="container">
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">🕐</div>
                <h3><%= t.about.f1.title %></h3>
                <p><%= t.about.f1.desc %></p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🚛</div>
                <h3><%= t.about.f2.title %></h3>
                <p><%= t.about.f2.desc %></p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">⚡</div>
                <h3><%= t.about.f3.title %></h3>
                <p><%= t.about.f3.desc %></p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🛡️</div>
                <h3><%= t.about.f4.title %></h3>
                <p><%= t.about.f4.desc %></p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">💰</div>
                <h3><%= t.about.f5.title %></h3>
                <p><%= t.about.f5.desc %></p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📍</div>
                <h3><%= t.about.f6.title %></h3>
                <p><%= t.about.f6.desc %></p>
            </div>
        </div>
    </div>

    <footer class="footer">
        <p>&copy; <%= t.footer.copyright %></p>
    </footer>

</body>
</html>
